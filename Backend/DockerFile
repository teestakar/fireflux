# Use official Python 3.10 slim image
# slim = smaller size, no unnecessary packages
FROM python:3.10-slim

# Set working directory inside container
WORKDIR /app

# Copy requirements first — Docker caches this layer
# So if code changes but requirements don't, it won't reinstall
COPY requirements.txt .

# Install dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy entire Backend folder into container
COPY . .

# Expose port 8000
EXPOSE 8000

# Start uvicorn
# host 0.0.0.0 — listen on all interfaces (required for Railway)
# port 8000 — match EXPOSE above
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]